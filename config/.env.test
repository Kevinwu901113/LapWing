# ═══════════════════════════════════════════════════════════════
# Phase 0 测试配置
# 用法：ENV_FILE=config/.env.test python main.py
# ═══════════════════════════════════════════════════════════════

# Phase 0 模式（A = 纯对话 0 工具，B = 加 5 个基础工具）
PHASE0_MODE=A

# ── 核心 LLM（从主 .env 复制你的 MiniMax 配置到这里）──
# LLM_CHAT_BASE_URL=
# LLM_CHAT_MODEL=
# LLM_CHAT_API_KEY=
# LLM_CHAT_PROVIDER=

# ── 通用 LLM（fallback）──
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# ── 通道（只保留 QQ）──
QQ_ENABLED=true
# QQ_WS_URL=ws://127.0.0.1:3001
# QQ_ACCESS_TOKEN=
# QQ_SELF_ID=
# QQ_KEVIN_ID=

# ── 全部关闭（MVP 清理后仍存在的开关）──
BROWSER_ENABLED=false
BROWSE_ENABLED=false
LOOP_DETECTION_ENABLED=false
SHELL_ENABLED=false
CHAT_WEB_TOOLS_ENABLED=false
AGENT_TEAM_ENABLED=false
EPISODIC_EXTRACT_ENABLED=false
SEMANTIC_DISTILL_ENABLED=false

# ── 日志 ──
LOG_LEVEL=DEBUG
