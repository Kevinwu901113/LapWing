# ═══════════════════════════════════════════════════════════════
# Phase 0 测试配置
# 用法：ENV_FILE=config/.env.test python main.py
# ═══════════════════════════════════════════════════════════════

# Phase 0 模式（A = 纯对话 0 工具，B = 加 5 个基础工具）
PHASE0_MODE=A

# ── 核心 LLM（从主 .env 复制你的 MiniMax 配置到这里）──
# LLM_CHAT_BASE_URL=
# LLM_CHAT_MODEL=
# LLM_CHAT_API_KEY=
# LLM_CHAT_PROVIDER=

# ── 通用 LLM（fallback）──
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# ── 通道（只保留 QQ）──
QQ_ENABLED=true
# QQ_WS_URL=ws://127.0.0.1:3001
# QQ_ACCESS_TOKEN=
# QQ_SELF_ID=
# QQ_KEVIN_ID=

# ── 全部关闭 ──
SKILLS_ENABLED=false
MEMORY_CRUD_ENABLED=false
AUTO_MEMORY_EXTRACT_ENABLED=false
SELF_SCHEDULE_ENABLED=false
SESSION_ENABLED=false
EXPERIENCE_SKILLS_ENABLED=false
QUALITY_CHECK_ENABLED=false
BROWSER_ENABLED=false
BROWSE_ENABLED=false
LOOP_DETECTION_ENABLED=false
SHELL_ENABLED=false
DELEGATION_ENABLED=false
CONSCIOUSNESS_ENABLED=false
HEARTBEAT_ENABLED=false
PROGRESS_REPORT_ENABLED=false
TASK_RESUMPTION_ENABLED=false
CHAT_WEB_TOOLS_ENABLED=false
INCIDENT_ENABLED=false
AGENT_TEAM_ENABLED=false
MEMORY_GUARD_ENABLED=false
MESSAGE_SPLIT_ENABLED=false

# ── 日志 ──
LOG_LEVEL=DEBUG
