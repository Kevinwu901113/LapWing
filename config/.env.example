# ===== Lapwing 环境变量覆盖层 =====
# 主配置在 config.toml（TOML 为主配置源）。
# 此文件仅用于：
#   1. 敏感凭据（API keys / tokens / secrets）
#   2. 环境特定覆盖（Docker/CI 场景）
# 任何 _ENV_MAP 中列出的变量都可在此覆盖 TOML 值。

# ── 敏感凭据（必填） ──────────────────

# QQ 身份
QQ_SELF_ID=
QQ_KEVIN_ID=
QQ_ACCESS_TOKEN=

# LLM API Keys
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=
LLM_TOOL_API_KEY=
LLM_TOOL_BASE_URL=

# NVIDIA NIM
NIM_API_KEY=nvapi-xxx

# 搜索
TAVILY_API_KEY=tvly-xxx
BOCHA_API_KEY=sk-xxx

# 浏览器视觉（留空则复用 LLM_CHAT_API_KEY）
MINIMAX_VLM_API_KEY=

# Whisper
WHISPER_API_KEY=

# 凭据保险柜（python main.py credential generate-key 生成）
CREDENTIAL_VAULT_KEY=

# ── 环境特定覆盖（按需） ──────────────

# 代理
SEARCH_PROXY_URL=
OPENAI_CODEX_AUTH_PROXY_URL=
CODEX_RUNTIME_PROXY_URL=

# 浏览器（.env 覆盖 config.toml 的 browser.enabled）
# BROWSER_ENABLED=true
# BROWSER_PROXY_SERVER=http://192.168.0.202:7890
