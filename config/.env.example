# 网络代理
SEARCH_PROXY_URL=   # 可选，搜索/网页抓取代理

# QQ (NapCat OneBot v11)
QQ_WS_URL=ws://127.0.0.1:3001
QQ_ACCESS_TOKEN=
QQ_SELF_ID=
QQ_KEVIN_ID=
QQ_GROUP_IDS=               # Comma-separated group IDs Lapwing may participate in
QQ_GROUP_CONTEXT_SIZE=30    # Number of recent messages to keep per group
QQ_GROUP_COOLDOWN=60        # Minimum seconds between group replies
QQ_GROUP_INTEREST_KEYWORDS= # Comma-separated interest keywords (optional)

# LLM 通用配置（所有 purpose 未单独配置时使用此配置）
# 支持 OpenAI 兼容和 Anthropic 兼容地址；若 base_url 包含 /anthropic 会自动切到 Anthropic SDK
LLM_API_KEY=你的_api_key
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=glm-4-flash
# 可选：显式声明通用 provider（如 openai/minimax/nvidia）
# 留空时会根据 base_url/model 自动推断
LLM_PROVIDER=

# LLM 多模型路由（可选，不填则回退到通用配置）
# 对话模型（人格对话，追求质量）
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=
LLM_CHAT_MODEL=
LLM_CHAT_PROVIDER=

# 工具模型（Agent 任务，追求速度和成本）
LLM_TOOL_API_KEY=
LLM_TOOL_BASE_URL=
LLM_TOOL_MODEL=
LLM_TOOL_PROVIDER=

# NVIDIA NIM（心跳后台模型，免费 API）
NIM_API_KEY=nvapi-...
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_PROVIDER=nvidia
# 同义配置（优先级高于 NIM_PROVIDER）
LLM_HEARTBEAT_PROVIDER=

# OpenAI / Codex OAuth（ChatGPT 登录，CLI `python main.py auth ...` 使用）
OPENAI_CODEX_AUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
OPENAI_CODEX_AUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_CODEX_AUTH_PROXY_URL=  # 可选，不填则自动回退到 SEARCH_PROXY_URL
OPENAI_CODEX_AUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OPENAI_CODEX_AUTH_REDIRECT_HOST=localhost
OPENAI_CODEX_AUTH_REDIRECT_PORT=1455
OPENAI_CODEX_AUTH_REDIRECT_PATH=/auth/callback
AUTH_REFRESH_SKEW_SECONDS=300

# 意识循环（inner tick） — 间隔在 MIN/MAX 之间自适应
CONSCIOUSNESS_DEFAULT_INTERVAL=600
CONSCIOUSNESS_MIN_INTERVAL=120
CONSCIOUSNESS_MAX_INTERVAL=14400
CONSCIOUSNESS_AFTER_CHAT_INTERVAL=120
CONSCIOUSNESS_CONVERSATION_END_DELAY=300

# 消息合并（防连发）
MESSAGE_BUFFER_SECONDS=4         # 等待多少秒无新消息后统一回复，默认 4 秒

# 本地 Shell 执行
SHELL_ENABLED=true
SHELL_TIMEOUT=30
SHELL_DEFAULT_CWD=/home/kevin/lapwing
SHELL_MAX_OUTPUT_CHARS=4000
TASK_MAX_TOOL_ROUNDS=32

# Latency / 体感 SLO（监控+告警）
TOOL_LOOP_SLO_SHELL_P95_MS=2000
TOOL_LOOP_SLO_WEB_P95_MS=5000
TOOL_LOOP_LONG_COMMAND_CUTOFF_MS=10000
TOOL_EVENT_START_TO_UI_P95_MS=200
TOOL_EVENT_UPDATE_THROTTLE_MS=500
TOOL_LATENCY_WINDOW_SIZE=200
TOOL_LATENCY_MIN_SAMPLES_FOR_SLO=20
# 是否允许 sudo 命令（默认禁止）
# 启用前必须在系统里配置 passwordless sudo，否则命令会因等待密码而超时：
#   sudo visudo -f /etc/sudoers.d/lapwing
#   kevin ALL=(ALL) NOPASSWD: /usr/bin/apt, /usr/bin/apt-get, /usr/bin/systemctl
# 如果信任该运行环境，也可以完全免密：kevin ALL=(ALL) NOPASSWD: ALL
SHELL_ALLOW_SUDO=false

# 工具循环检测
LOOP_DETECTION_ENABLED=true
LOOP_DETECTION_HISTORY_SIZE=30
LOOP_DETECTION_WARNING_THRESHOLD=10
LOOP_DETECTION_CRITICAL_THRESHOLD=20
LOOP_DETECTION_GLOBAL_CIRCUIT_BREAKER_THRESHOLD=30
LOOP_DETECTION_DETECTOR_GENERIC_REPEAT=true
LOOP_DETECTION_DETECTOR_PING_PONG=true
LOOP_DETECTION_DETECTOR_KNOWN_POLL_NO_PROGRESS=true

# 搜索（Researcher Agent）
CHAT_WEB_TOOLS_ENABLED=true  # 是否在主对话工具闭环中开放 web_search/web_fetch
TAVILY_API_KEY=               # Tavily API key（可选；设置后 Tavily 成为主搜索引擎）

# 本地 API Auth（桌面端 / 浏览器只允许本机来源）
API_HOST=127.0.0.1
API_PORT=8765
API_SESSION_COOKIE_NAME=lapwing_session
API_SESSION_TTL_SECONDS=43200
API_ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://127.0.0.1:8765,tauri://localhost,http://tauri.localhost,https://tauri.localhost

# 浏览器子系统
BROWSER_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_MAX_TABS=8
BROWSER_PAGE_TEXT_MAX_CHARS=4000
BROWSER_NAVIGATION_TIMEOUT_MS=30000
BROWSER_ACTION_TIMEOUT_MS=10000
BROWSER_SCREENSHOT_RETAIN_DAYS=7
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
BROWSER_LOCALE=zh-CN
BROWSER_TIMEZONE=Asia/Shanghai
BROWSER_MAX_ELEMENT_COUNT=50
BROWSER_WAIT_AFTER_ACTION_MS=1000
BROWSER_URL_BLACKLIST=
BROWSER_URL_WHITELIST=              # 非空时启用白名单模式（fail-closed），只允许列出的域名
BROWSER_BLOCK_INTERNAL_NETWORK=true
# 浏览器视觉理解（gpt-5.4 via Codex Runtime）
BROWSER_VISION_ENABLED=true
BROWSER_VISION_SLOT=browser_vision
BROWSER_VISION_MAX_DESCRIPTION_CHARS=500
BROWSER_VISION_CACHE_TTL_SECONDS=30
BROWSER_VISION_IMG_THRESHOLD=5
BROWSER_VISION_ALT_RATIO_THRESHOLD=0.3
# MiniMax VLM 端点（浏览器视觉理解的替代方案，优先于 LLMRouter vision slot）
MINIMAX_VLM_ENABLED=false
MINIMAX_VLM_API_KEY=           # 留空则复用 LLM_CHAT_API_KEY 或 LLM_API_KEY
MINIMAX_VLM_HOST=https://api.minimaxi.com
# 凭据保险柜（用于 browser_login，密钥用 `python main.py credential generate-key` 生成）
CREDENTIAL_VAULT_KEY=

# 记忆树（Step 7：情景 + 语义）
EPISODIC_EXTRACT_ENABLED=true
SEMANTIC_DISTILL_ENABLED=true

# Agent Team
AGENT_TEAM_ENABLED=true

# 桌面端权限（仅 localhost 可信环境）
DESKTOP_DEFAULT_OWNER=true

# 日志级别
LOG_LEVEL=INFO
