# Telegram
TELEGRAM_TOKEN=你的_telegram_bot_token
TELEGRAM_PROXY_URL=  # 可选，如 http://192.168.0.202:7890
SEARCH_PROXY_URL=   # 可选，搜索/网页抓取代理；不填则复用 TELEGRAM_PROXY_URL

# LLM 通用配置（所有 purpose 未单独配置时使用此配置）
# 支持 OpenAI 兼容和 Anthropic 兼容地址；若 base_url 包含 /anthropic 会自动切到 Anthropic SDK
LLM_API_KEY=你的_api_key
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=glm-4-flash

# LLM 多模型路由（可选，不填则回退到通用配置）
# 对话模型（人格对话，追求质量）
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=
LLM_CHAT_MODEL=

# 工具模型（Agent 任务，追求速度和成本）
LLM_TOOL_API_KEY=
LLM_TOOL_BASE_URL=
LLM_TOOL_MODEL=

# NVIDIA NIM（心跳后台模型，免费 API）
NIM_API_KEY=nvapi-...
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct

# 心跳（测试时将 HEARTBEAT_FAST_INTERVAL_MINUTES 设为 3）
HEARTBEAT_ENABLED=true
HEARTBEAT_FAST_INTERVAL_MINUTES=60
HEARTBEAT_SLOW_HOUR=3
HEARTBEAT_MINUTE_ENABLED=true
HEARTBEAT_MINUTE_INTERVAL_SECONDS=60

# 自主浏览（后台探索 + 知识沉淀）
BROWSE_ENABLED=true
BROWSE_INTERVAL_HOURS=2
BROWSE_SOURCES=hackernews,reddit/technology,reddit/science

# 提醒派发（分钟心跳消费提醒任务）
REMINDER_DISPATCH_GRACE_SECONDS=60
REMINDER_MAX_DUE_PER_CHAT=20

# 消息合并（防连发）
MESSAGE_BUFFER_SECONDS=4         # 等待多少秒无新消息后统一回复，默认 4 秒

# 用户画像提取（可选，调整提取触发条件）
FACT_EXTRACT_IDLE_SECONDS=300    # 用户空闲多少秒后触发提取，默认 5 分钟
FACT_EXTRACT_TURN_THRESHOLD=3    # 对话满多少轮触发提取，默认 3 轮
INTEREST_EXTRACT_TURN_THRESHOLD=5  # 对话满多少轮触发兴趣提取，默认 5 轮

# 语音转写（Whisper，可选；不填则用 LLM_API_KEY + LLM_BASE_URL 回退）
WHISPER_API_KEY=
WHISPER_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1

# 本地 Shell 执行
SHELL_ENABLED=true
SHELL_TIMEOUT=30
SHELL_DEFAULT_CWD=/home/kevin/lapwing
SHELL_MAX_OUTPUT_CHARS=4000
TASK_MAX_TOOL_ROUNDS=32

# Skills（OpenClaw-compatible）
SKILLS_ENABLED=true
SKILLS_COMMANDS_ENABLED=true
# 目录优先级：workspace(最高) > managed > bundled > extraDirs(最低)
SKILLS_WORKSPACE_DIR=/home/kevin/lapwing/skills
SKILLS_MANAGED_DIR=/home/kevin/.lapwing/skills
SKILLS_BUNDLED_DIR=/home/kevin/lapwing/bundled_skills
SKILLS_EXTRA_DIRS=
# command-dispatch:tool 白名单（逗号分隔）
SKILLS_DISPATCH_TOOL_WHITELIST=execute_shell

# Latency / 体感 SLO（监控+告警）
TOOL_LOOP_SLO_SHELL_P95_MS=2000
TOOL_LOOP_SLO_WEB_P95_MS=5000
TOOL_LOOP_LONG_COMMAND_CUTOFF_MS=10000
TOOL_EVENT_START_TO_UI_P95_MS=200
TOOL_EVENT_UPDATE_THROTTLE_MS=500
TOOL_LATENCY_WINDOW_SIZE=200
TOOL_LATENCY_MIN_SAMPLES_FOR_SLO=20
# 是否允许 sudo 命令（默认禁止）
# 启用前必须在系统里配置 passwordless sudo，否则命令会因等待密码而超时：
#   sudo visudo -f /etc/sudoers.d/lapwing
#   kevin ALL=(ALL) NOPASSWD: /usr/bin/apt, /usr/bin/apt-get, /usr/bin/systemctl
# 如果信任该运行环境，也可以完全免密：kevin ALL=(ALL) NOPASSWD: ALL
SHELL_ALLOW_SUDO=false

# 工具循环检测（OpenClaw 语义，MVP 仅实现 genericRepeat）
LOOP_DETECTION_ENABLED=false
LOOP_DETECTION_HISTORY_SIZE=30
LOOP_DETECTION_WARNING_THRESHOLD=10
LOOP_DETECTION_CRITICAL_THRESHOLD=20
LOOP_DETECTION_GLOBAL_CIRCUIT_BREAKER_THRESHOLD=30
LOOP_DETECTION_DETECTOR_GENERIC_REPEAT=true
LOOP_DETECTION_DETECTOR_PING_PONG=true
LOOP_DETECTION_DETECTOR_KNOWN_POLL_NO_PROGRESS=true

# 搜索（Researcher Agent）
SEARCH_MAX_RESULTS=5    # 每次搜索返回的最大结果数

# 日志级别
LOG_LEVEL=INFO
