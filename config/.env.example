# ===== Lapwing 敏感凭据 =====
# 非敏感配置请编辑项目根目录的 config.toml

# QQ 身份
QQ_SELF_ID=
QQ_KEVIN_ID=
QQ_ACCESS_TOKEN=

# LLM API Keys（通用 + 多模型路由）
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=
LLM_TOOL_API_KEY=
LLM_TOOL_BASE_URL=

# NVIDIA NIM
NIM_API_KEY=nvapi-xxx

# 搜索
TAVILY_API_KEY=tvly-xxx
BOCHA_API_KEY=sk-xxx

# 代理（仅在需要时填）
SEARCH_PROXY_URL=
OPENAI_CODEX_AUTH_PROXY_URL=
CODEX_RUNTIME_PROXY_URL=

# 浏览器视觉（留空则复用 LLM_CHAT_API_KEY）
MINIMAX_VLM_API_KEY=

# Whisper
WHISPER_API_KEY=

# 凭据保险柜（python main.py credential generate-key 生成）
CREDENTIAL_VAULT_KEY=

# === 安全配置 ===
# 是否允许 shell 工具执行 sudo（生产环境建议 false）
# SHELL_ALLOW_SUDO=false
# 桌面连接是否默认 OWNER 权限（仅限本地单用户场景）
# DESKTOP_DEFAULT_OWNER=false

# === LLM 模型路由 ===
# LLM_MODEL=MiniMax-M2.7              # 默认模型
# LLM_PROVIDER=minimax                # 默认 provider
# LLM_CHAT_MODEL=                     # chat slot 覆盖（留空走 LLM_MODEL）
# LLM_TOOL_MODEL=                     # tool slot 覆盖
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_MODEL=moonshotai/kimi-k2-instruct

# === QQ 适配器 ===
# QQ_ENABLED=true                     # 启用 QQ 通道
# QQ_WS_URL=ws://127.0.0.1:3001      # NapCat WebSocket URL
# QQ_GROUP_IDS=                       # 允许的群 ID（逗号分隔）

# === 意识循环 ===
# CONSCIOUSNESS_DEFAULT_INTERVAL=600  # 自主思考间隔（秒）
# CONSCIOUSNESS_MIN_INTERVAL=120
# CONSCIOUSNESS_MAX_INTERVAL=14400

# === Shell 执行 ===
# SHELL_ENABLED=true
# SHELL_TIMEOUT=30                    # 命令超时（秒）
# SHELL_MAX_OUTPUT_CHARS=4000
# SHELL_BACKEND=local                 # local | docker

# === 沙箱 ===
# SANDBOX_DOCKER_IMAGE=lapwing-sandbox:latest
# SANDBOX_NETWORK=lapwing-sandbox

# === 记忆 ===
# EPISODIC_EXTRACT_ENABLED=true
# SEMANTIC_DISTILL_ENABLED=true

# === 浏览器（默认关闭）===
# BROWSER_ENABLED=false
# BROWSER_HEADLESS=true
# BROWSER_TIMEZONE=Asia/Shanghai

# === 技能系统（默认关闭）===
# SKILL_SYSTEM_ENABLED=false

# === API 服务 ===
# API_HOST=0.0.0.0
# API_PORT=8765

# === 日志 ===
# LOG_LEVEL=INFO
